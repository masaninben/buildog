rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 掲示板の写真：認証済みユーザーなら読み書き可
    match /boards/{boardId}/photos/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /projects/{projectId}/{fileName} {
      // 読み取り: 案件が公開、またはオーナー
      allow read: if (
        get(/databases/(default)/documents/projects/$(projectId)).data.isPublic == true
      ) || (
        request.auth != null
        && get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );

      // 書き込み: オーナーのみ・画像ファイルのみ・10MB 以下
      allow write: if request.auth != null
        && get(/databases/(default)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
