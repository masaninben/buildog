rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ユーザーは自分のフォルダにのみ書き込み可、読み込みは全員可
    match /users/{uid}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024; // 10MB上限
    }
  }
}
