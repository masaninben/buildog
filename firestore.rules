rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール
    // 書き込みは本人のみ。読み取りは認証済みユーザー全員（メンバー招待時のメール検索に使用）
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 運営管理者ドキュメント（Firebase Console から手動作成、クライアントからは読み取りのみ）
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // メンバーサブコレクションのコレクショングループ読み取り
    // （メンバー自身が自分の所属組織を検索するために使用）
    match /{path=**}/members/{memberId} {
      allow read: if request.auth != null && request.auth.uid == memberId;
    }

    // 組織
    match /organizations/{orgId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'plan', 'trialEndsAt', 'createdAt']);

      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // メンバーサブコレクション
      match /members/{memberId} {
        // オーナーは全メンバーを読み書き可
        // メンバー自身は自分のドキュメントを読める
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
          || request.auth.uid == memberId
        );
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
      }
    }

    match /projects/{projectId} {
      // 読み取り: 公開案件 / オーナー / その案件が属する組織のメンバー
      allow read: if resource.data.isPublic == true
        || (request.auth != null && resource.data.ownerId == request.auth.uid)
        || (request.auth != null
            && resource.data.orgId != ''
            && exists(/databases/$(database)/documents/organizations/$(resource.data.orgId)/members/$(request.auth.uid)));

      // 新規作成: ownerId は自分のUID・必須フィールド存在チェック
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'isPublic', 'createdAt', 'updatedAt']);

      // 更新: オーナーのみ・ownerId 書き換え禁止
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      // 削除: オーナーのみ
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      match /photos/{photoId} {
        // 読み取り: 案件が公開かつ写真が公開、またはオーナー、または組織メンバー
        allow read: if (
          get(/databases/$(database)/documents/projects/$(projectId)).data.isPublic == true
          && resource.data.isPublic == true
        ) || (
          request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        ) || (
          request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.orgId != ''
          && exists(/databases/$(database)/documents/organizations/$(get(/databases/$(database)/documents/projects/$(projectId)).data.orgId)/members/$(request.auth.uid))
        );

        // 写真追加: オーナーのみ・uploadedBy は自分の UID
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
          && request.resource.data.uploadedBy == request.auth.uid;

        // 写真更新・削除: オーナーのみ
        allow update, delete: if request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
