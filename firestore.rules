rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール（plan・trialEndsAt含む）
    match /users/{uid} {
      allow read: if request.auth != null;
      // 自分自身は全フィールド書き込み可
      allow write: if request.auth != null && request.auth.uid == uid;
      // 他の認証済みユーザーは sharedProjectIds フィールドのみ更新可（招待時の書き込み）
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedProjectIds']);
    }

    // 運営管理者（Firebase Console で手動作成、クライアントは読み取りのみ）
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // collection group: 自分の member ドキュメントを読める（共有案件一覧取得に使用）
    match /{path=**}/members/{memberId} {
      allow read: if request.auth != null && request.auth.uid == memberId;
    }

    match /projects/{projectId} {

      function isOwner() {
        return request.auth != null && resource.data.ownerId == request.auth.uid;
      }

      function isMember() {
        return request.auth != null
          && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
      }

      // 掲示板のアクティブメンバー（施主など）も案件ドキュメントを読める
      function isActiveBoardMember() {
        let boardId = resource.data.boardId;
        return boardId != null
          && request.auth != null
          && exists(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data.status == 'active';
      }

      // 読み取り: 公開案件 / オーナー / メンバー / 掲示板アクティブメンバー
      allow read: if resource.data.isPublic == true
        || isOwner()
        || isMember()
        || isActiveBoardMember();

      // 新規作成: ownerId は自分・必須フィールド存在チェック
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'ownerId', 'isPublic', 'createdAt', 'updatedAt']);

      // 更新: オーナーのみ・ownerId 書き換え禁止
      allow update: if isOwner()
        && request.resource.data.ownerId == resource.data.ownerId;

      // 削除: オーナーのみ
      allow delete: if isOwner();

      // メンバーサブコレクション
      match /members/{memberId} {
        function projectOwnerId() {
          return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId;
        }

        function isProjectOwner() {
          return request.auth != null && projectOwnerId() == request.auth.uid;
        }

        function hasInvitePermission() {
          return request.auth != null
            && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid))
            && get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.canInvite == true;
        }

        // 読み取り: オーナー / 自分のドキュメント
        allow read: if request.auth != null && (
          isProjectOwner()
          || request.auth.uid == memberId
        );

        // 招待 (create): オーナー または canInvite メンバー
        allow create: if isProjectOwner() || hasInvitePermission();

        // 権限変更・削除: オーナーのみ
        allow update, delete: if isProjectOwner();
      }

      // 写真サブコレクション
      match /photos/{photoId} {
        function projectData() {
          return get(/databases/$(database)/documents/projects/$(projectId)).data;
        }

        function isProjectOwner() {
          return request.auth != null && projectData().ownerId == request.auth.uid;
        }

        function isProjectMember() {
          return request.auth != null
            && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
        }

        function canEdit() {
          return request.auth != null
            && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid))
            && get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.canEdit == true;
        }

        // 掲示板メンバーが公開写真を読めるか確認
        function isActiveBoardMemberForPhotos() {
          let boardId = projectData().boardId;
          return boardId != null
            && request.auth != null
            && exists(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid))
            && get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data.status == 'active';
        }

        // 読み取り: 公開案件の公開写真 / オーナー / メンバー / 掲示板メンバー（公開写真のみ）
        allow read: if (projectData().isPublic == true && resource.data.isPublic == true)
          || isProjectOwner()
          || isProjectMember()
          || (isActiveBoardMemberForPhotos() && resource.data.isPublic == true);

        // 写真追加: オーナー または canEdit メンバー・uploadedBy は自分の UID
        allow create: if (isProjectOwner() || canEdit())
          && request.resource.data.uploadedBy == request.auth.uid;

        // 写真更新・削除: オーナー または canEdit メンバー
        allow update, delete: if isProjectOwner() || canEdit();
      }
    }

    // ===== 連絡掲示板 =====
    match /boards/{boardId} {

      function isActiveMember() {
        let member = get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data;
        return request.auth != null && member != null && member.status == 'active';
      }

      function isBoardManager() {
        let member = get(/databases/$(database)/documents/boards/$(boardId)/members/$(request.auth.uid)).data;
        return request.auth != null && member != null && member.role == 'manager' && member.status == 'active';
      }

      // boardDoc: activeメンバーのみ読み取り / 認証ユーザーなら作成可 / 管理者のみ更新
      allow read:   if isActiveMember();
      allow create: if request.auth != null;
      allow update: if isBoardManager() || isActiveMember();

      match /messages/{messageId} {
        allow read:   if isActiveMember();
        allow create: if isActiveMember();
        // readBy 追記のみ許可
        allow update: if isActiveMember();
      }

      match /members/{uid} {
        allow read:    if isActiveMember();
        // 作成: 認証済みユーザーなら可（掲示板初期化時を含む）
        allow create:  if request.auth != null;
        // 更新・削除: 管理者のみ
        allow update, delete: if isBoardManager();
      }
    }
  }
}
